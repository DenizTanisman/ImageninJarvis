# Copy to backend/.env and fill in real values. Never commit .env.
ENV=dev

# CORS — comma-separated list
CORS_ORIGINS=http://localhost:5173

# Gemini (Step 1+)
GEMINI_API_KEY=
# Optional override; leave blank for default (gemini-2.5-flash).
# Other current candidates: gemini-2.5-pro (slower, smarter),
# gemini-flash-latest (alias).
GEMINI_MODEL=

# Google OAuth — Gmail + Calendar + Drive (Step 2+)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Encryption for stored OAuth tokens (cryptography.fernet 32-byte urlsafe base64)
ENCRYPTION_KEY=

# SQLite path
DATABASE_URL=sqlite:///./jarvis.db
